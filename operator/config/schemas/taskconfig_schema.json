{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TaskConfig",
  "description": "Configuration for a Marvin task, serialized into the FLOKOA_TASK_CONFIG env var by the operator compiler.",
  "type": "object",
  "properties": {
    "type": {
      "type": "string",
      "enum": [
        "run",
        "classify",
        "extract",
        "cast",
        "generate"
      ],
      "description": "The Marvin operation to perform."
    },
    "instructions": {
      "type": "string",
      "description": "Prompt or guidance for the task."
    },
    "input": {
      "type": "string",
      "description": "Data to process (classify, extract, cast)."
    },
    "resultType": {
      "title": "TaskResultType",
      "type": "object",
      "description": "Output type constraint via JSON Schema.",
      "properties": {
        "name": {
          "type": "string",
          "description": "Name of the result type."
        },
        "description": {
          "type": "string",
          "description": "Description of the result type."
        },
        "jsonSchema": {
          "description": "JSON Schema defining the result structure."
        }
      },
      "required": [
        "name",
        "description",
        "jsonSchema"
      ]
    },
    "labels": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Labels for classify operations."
    },
    "multiLabel": {
      "type": "boolean",
      "description": "Enable multi-label classification."
    },
    "count": {
      "type": "integer",
      "minimum": 1,
      "description": "Number of items to generate."
    },
    "context": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      },
      "description": "Key-value context data passed to Marvin."
    },
    "agent": {
      "title": "TaskAgentConfig",
      "type": "object",
      "description": "Inline Marvin agent configuration.",
      "properties": {
        "name": {
          "type": "string",
          "description": "Agent name."
        },
        "instructions": {
          "type": "string",
          "description": "Agent instructions."
        }
      },
      "required": [
        "name"
      ]
    }
  },
  "required": [
    "type"
  ]
}
