{
  "model": "anthropic:claude-sonnet-4-5",
  "name": "support-agent",
  "description": "Customer support agent",
  "instructions": [
    "You are a helpful support agent.",
    "Answer based on the knowledge base only."
  ],
  "model_settings": {
    "max_tokens": 4096,
    "temperature": 0.2,
    "parallel_tool_calls": true,
    "extra_body": {
      "service_tier": "default"
    }
  },
  "output_schema": {
    "type": "object",
    "properties": {
      "answer": {
        "type": "string"
      }
    },
    "required": [
      "answer"
    ]
  },
  "metadata": {
    "flokoa.ai/agent": "support-agent"
  },
  "capabilities": [
    {
      "MCP": {
        "url": "http://kb-tools.default.svc.cluster.local:8080/mcp",
        "native": false,
        "local": true,
        "id": "kb",
        "headers": {
          "Authorization": "${secret:kb-token}"
        },
        "allowed_tools": [
          "search",
          "fetch_article"
        ]
      }
    },
    {
      "WebSearch": {
        "native": true
      }
    },
    "Thinking"
  ]
}
